{
  "name": "careplus-frontend",
  "private": true,
  "version": "0.1.0-SNAPSHOT",
  "type": "module",
  "description": "careplus — SICM frontend (React 18 + Vite + TypeScript). See docs/FRONTEND.md for the defended stack.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/instrument-serif": "5.1.0",
