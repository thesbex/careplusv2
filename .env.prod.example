# careplus — production env template.
# Copy to .env.prod and fill in. NEVER commit .env.prod.
#
# Used by docker-compose.prod.yml (self-hosted / VPS / cabinet on-premise).

# --- Image -------------------------------------------------------------------
# Tag from your registry, e.g. ghcr.io/<owner>/careplus:0.1.0
# Leave at "careplus:local" if you build locally with `docker build -t careplus:local .`
CAREPLUS_IMAGE=careplus:local

# --- Database ----------------------------------------------------------------
POSTGRES_DB=careplus
POSTGRES_USER=careplus
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-strong-password

# --- App ---------------------------------------------------------------------
APP_PORT=8080
# Generate: openssl rand -hex 32
CAREPLUS_JWT_SECRET=change-me-64-hex-chars

# Optional: override JVM tuning (default sized for 512 MB Render free tier).
# For a 2 GB VPS: -XX:MaxRAMPercentage=75 -XX:+UseG1GC -Duser.timezone=Africa/Casablanca
# JAVA_TOOL_OPTIONS=
